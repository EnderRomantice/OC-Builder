{
  "name": "oc-builder-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "agent:build": "pnpm --filter @oc-builder/agent build",
    "agent:check": "pnpm --filter @oc-builder/agent check",
    "agent:dev": "pnpm --filter @oc-builder/agent dev",
    "agent:start": "pnpm --filter @oc-builder/agent start",
    "service:build": "pnpm --filter @oc-builder/service build",
    "service:start": "pnpm --filter @oc-builder/service start",
    "service:dev": "pnpm --filter @oc-builder/service start:dev",
    "service:migrate": "pnpm --filter @oc-builder/service db:migrate",
    "service:studio": "pnpm --filter @oc-builder/service db:studio"
  }
}
