{
	"name": "@oc-builder/agent",
	"version": "1.0.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/EnderRomantice/OC-Builder.git"
	},
	"packageManager": "pnpm@11.1.2",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"prestart": "pnpm run build",
		"start": "node dist/index.js",
		"build": "tsc",
		"check": "tsc --noEmit",
		"check:browser-smoke": "echo 'Skipping browser smoke check (no browser UI)'",
		"dev": "tsc -w"
	},
	"dependencies": {
		"@sinclair/typebox": "^0.34.49",
		"dotenv": "^16.4.7",
		"openai": "6.26.0",
		"wechaty": "^1.20.2",
		"wechaty-puppet-wechat": "^1.18.4"
	},
	"devDependencies": {
		"@types/node": "^24.12.4",
		"typescript": "^5.9.3"
	}
}
