# DeepSeek-compatible OpenAI SDK configuration
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com
CHARACTER_MODEL=deepseek-chat

# Optional web search endpoint used by tools
SEARXNG_URL=https://searx.be/

# Optional WeChaty runtime settings
WECHATY_NAME=pi-wechat-bot

# Message coalescing and outbound pacing.
# Coalesce raw WeChat messages before creating a runtime event.
WECHAT_INCOMING_BATCH_MS=6000
# Coalesce fast incoming messages in the same conversation before one AI response.
AGENT_MESSAGE_COALESCE_MS=3500
# Serialize all outbound messages per WeChat account. Conservative defaults reduce risk-control hits.
WECHAT_SEND_INTERVAL_MS=4000
WECHAT_SAME_TARGET_EXTRA_INTERVAL_MS=2000
WECHAT_RESTART_BASE_DELAY_MS=30000
WECHAT_RESTART_MAX_DELAY_MS=300000
WECHAT_LOGIN_SETTLE_MS=20000

# Proactive task runtime. Runs inside agent:start after WeChat login.
PROACTIVE_MODEL=deepseek-chat
PROACTIVE_POLL_MS=30000
PROACTIVE_TASK_LIMIT=10
PROACTIVE_RETRY_MS=300000
PROACTIVE_PLANNER_POLL_MS=1800000
PROACTIVE_PLANNER_CONTACT_LIMIT=20

# Optional multi-character runtime.
# Default is one character. To run multiple sessions, list character ids in order.
# Built-ins: kaede-akamatsu, enromantice (display name: 苏格拉底)
# AGENT_CHARACTERS=kaede-akamatsu,enromantice
#
# Optional per-character overrides by ordinal:
# CHARACTER_1_DISPLAY_NAME=赤松枫
# CHARACTER_2_DISPLAY_NAME=苏格拉底

# OC-Builder backend service
OC_BUILDER_SERVICE_URL=http://127.0.0.1:3001/api
